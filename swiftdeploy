# --- Manifest I/O ---

def load_manifest():
    """Reads manifest.yaml and converts it into a Python dictionary."""
    with MANIFEST.open("r", encoding="utf-8") as f:
        if yaml is not None:
            data = yaml.safe_load(f)
        else:
            data = parse_simple_yaml(f.read())
    if not isinstance(data, dict):
        raise ValueError("manifest.yaml must contain a YAML object")
    return data


def save_manifest(manifest):
    """Writes the Python dictionary back to manifest.yaml."""
    with MANIFEST.open("w", encoding="utf-8") as f:
        if yaml is not None:
            yaml.safe_dump(manifest, f, sort_keys=False)
        else:
            f.write(dump_simple_yaml(manifest))


def coerce_scalar(value):
    """Converts string values from YAML into proper Python types (int, bool)."""
    value = value.strip()
    if value == "":
        return ""
    if value.lower() in {"true", "false"}:
        return value.lower() == "true"
    try:
        return int(value)
    except ValueError:
        return value.strip("'\"")


def parse_simple_yaml(content):
    """A fallback YAML parser if the 'yaml' module is not installed."""
    data = {}
    current_section = None
    for raw_line in content.splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        if not raw_line.startswith(" ") and raw_line.endswith(":"):
            current_section = raw_line[:-1].strip()
            data[current_section] = {}
            continue
        if raw_line.startswith("  ") and current_section:
            key, sep, value = raw_line.strip().partition(":")
            if not sep:
                raise ValueError(f"invalid manifest line: {raw_line}")
            data[current_section][key] = coerce_scalar(value)
            continue
        raise ValueError(f"unsupported manifest line: {raw_line}")
    return data


def dump_simple_yaml(data):
    """Serializes a Python dictionary back into a YAML-formatted string."""
    lines = []
    for section, values in data.items():
        lines.append(f"{section}:")
        if isinstance(values, dict):
            for key, value in values.items():
                lines.append(f"  {key}: {value}")
        else:
            lines.append(f"  value: {values}")
        lines.append("")
    return "\n".join(lines).rstrip() + "\n"


def require_fields(manifest):
    """Ensures all mandatory fields are present in the manifest."""
    missing = []
    for section, fields in REQUIRED_FIELDS.items():
        if not isinstance(manifest.get(section), dict):
            missing.append(section)
            continue
        for field in fields:
            value = manifest[section].get(field)
            if value is None or value == "":
                missing.append(f"{section}.{field}")
    if missing:
        raise ValueError("missing required field(s): " + ", ".join(missing))


def render_template(name, values):
    """Populates placeholders in template files with real values from the manifest."""
    template = (TEMPLATE_DIR / name).read_text(encoding="utf-8")
    for key, value in values.items():
        template = template.replace("{{" + key + "}}", str(value))
    return template


# --- Policy & Metrics ---

def query_opa(policy, payload):
    """Sends a query to the OPA server and returns a structured result."""
    manifest = load_manifest()
    opa_url = manifest.get("policy", {}).get("opa_url", "http://127.0.0.1:8181").rstrip("/")
    url = f"{opa_url}/v1/data/{policy}"
    data = json.dumps({"input": payload}).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=5) as response:
            res = json.loads(response.read().decode("utf-8"))
            result = res.get("result")
            if not isinstance(result, dict):
                return {
                    "allow": False,
                    "reasons": [f"OPA returned an invalid decision for {policy}: expected object, got {type(result).__name__}"],
                    "failure": "invalid_response",
                }
            result.setdefault("reasons", [])
            return result
    except urllib.error.HTTPError as e:
        return {"allow": False, "reasons": [f"OPA HTTP error while querying {policy}: {e.code} {e.reason}"], "failure": "http_error"}
    except urllib.error.URLError as e:
        return {"allow": False, "reasons": [f"OPA unavailable while querying {policy}: {e.reason}"], "failure": "unavailable"}
    except TimeoutError:
        return {"allow": False, "reasons": [f"OPA timed out while querying {policy}"], "failure": "timeout"}
    except json.JSONDecodeError:
        return {"allow": False, "reasons": [f"OPA returned non-JSON response for {policy}"], "failure": "bad_json"}


def check_predeploy():
    """Checks infrastructure policy (disk, CPU) before allowing a deploy."""
    print("Running pre-deploy policy checks...")
    try:
        manifest = load_manifest()
        policy = manifest.get("policy", {})
        usage = shutil.disk_usage(ROOT)
        disk_free = round(usage.free / (1024 ** 3), 2)
        cpu_load = os.getloadavg()[0] if hasattr(os, "getloadavg") else 0.0

        payload = {
            "disk_free": disk_free,
            "min_disk": float(policy.get("infra_min_disk_gb", 10)),
            "cpu_load": cpu_load,
            "max_cpu": float(policy.get("infra_max_cpu_load", 2.0)),
            "question": "pre-deploy",
        }

        result = query_opa("infra", payload)
        if not result.get("allow", True):
            print("DEPLOY BLOCKED by infra policy:")
            for reason in result.get("reasons", []):
                print(f" - {reason}")
            append_history({"action": "policy_check", "domain": "infra", "success": False, "detail": result.get("reasons", []), "input": payload})
            return False

        append_history({"action": "policy_check", "domain": "infra", "success": True, "detail": result.get("reasons", []), "input": payload})
        print("PASS: Infra policy check passed.")
        return True
    except Exception as e:
        print(f"ERROR: Failed to run pre-deploy checks: {e}")
        return False


def check_prepromote(manifest):
    """Checks canary health (error rate, latency) before allowing a promotion."""
    print("Running pre-promote policy checks...")
    try:
        policy = manifest.get("policy", {})
        window_seconds = int(policy.get("canary_window_seconds", 30))
        print(f"Sampling canary metrics for {window_seconds}s...")
        before = scrape_metrics_snapshot(manifest)
        time.sleep(window_seconds)
        after = scrape_metrics_snapshot(manifest)

        before_requests = before["raw"]["requests"]
        after_requests = after["raw"]["requests"]
        total_delta = 0.0
        error_delta = 0.0
        for key, after_value in after_requests.items():
            delta = max(after_value - before_requests.get(key, 0.0), 0.0)
            total_delta += delta
            if key[2].startswith("5"):
                error_delta += delta
        error_rate = error_delta / total_delta if total_delta else 0.0

        before_buckets = before["raw"]["buckets"]
        after_buckets = after["raw"]["buckets"]
        window_buckets = {
            le: max(after_value - before_buckets.get(le, 0.0), 0.0)
            for le, after_value in after_buckets.items()
        }
        latency_p99 = histogram_quantile(0.99, window_buckets)

        payload = {
            "error_rate": error_rate,
            "max_error_rate": float(policy.get("canary_max_error_rate", 0.01)),
            "p99_latency": latency_p99,
            "max_latency": float(policy.get("canary_max_p99_latency_seconds", 0.5)),
            "window_seconds": window_seconds,
            "question": "pre-promote",
        }

        result = query_opa("canary", payload)
        if not result.get("allow", True):
            print("PROMOTION BLOCKED by canary policy:")
            for reason in result.get("reasons", []):
                print(f" - {reason}")
            append_history({"action": "policy_check", "domain": "canary", "success": False, "detail": result.get("reasons", []), "input": payload})
            return False

        append_history({"action": "policy_check", "domain": "canary", "success": True, "detail": result.get("reasons", []), "input": payload})
        print("PASS: Canary policy check passed.")
        return True
    except Exception as e:
        print(f"ERROR: Failed to run pre-promote checks: {e}")
        return False


def parse_labels(label_text):
    labels = {}
    for part in re.findall(r'(\w+)="([^"]*)"', label_text):
        labels[part[0]] = part[1]
    return labels


def parse_prometheus_metrics(metrics_text):
    counters = {}
    buckets = {}
    mode = None
    uptime = None
    chaos = None
    for raw in metrics_text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        pieces = line.rsplit(None, 1)
        if len(pieces) != 2:
            continue
        metric, value_text = pieces
        try:
            value = float(value_text)
        except ValueError:
            continue
        if metric.startswith("http_requests_total{"):
            labels = parse_labels(metric)
            key = (labels.get("method", ""), labels.get("path", ""), labels.get("status_code", ""))
            counters[key] = value
        elif metric.startswith("http_request_duration_seconds_bucket{"):
            labels = parse_labels(metric)
            le = labels.get("le")
            if le:
                buckets[le] = value
        elif metric == "app_mode":
            mode = value
        elif metric == "app_uptime_seconds":
            uptime = value
        elif metric == "chaos_active":
            chaos = value
    return {"requests": counters, "buckets": buckets, "mode": mode, "uptime": uptime, "chaos": chaos}


def histogram_quantile(q, buckets):
    finite = []
    total = 0.0
    for le, count in buckets.items():
        if le == "+Inf":
            total = max(total, count)
            continue
        try:
            finite.append((float(le), count))
        except ValueError:
            continue
    finite.sort()
    if total <= 0 and finite:
        total = finite[-1][1]
    if total <= 0:
        return 0.0
    target = q * total
    for bound, cumulative in finite:
        if cumulative >= target:
            return bound
    return finite[-1][0] if finite else 0.0


def scrape_metrics_snapshot(manifest):
    port = manifest["nginx"]["port"]
    url = f"http://127.0.0.1:{port}/metrics"
    with urllib.request.urlopen(url, timeout=5) as response:
        metrics_text = response.read().decode("utf-8")
    parsed = parse_prometheus_metrics(metrics_text)
    total = sum(parsed["requests"].values())
    errors = sum(value for (_method, _path, status), value in parsed["requests"].items() if status.startswith("5"))
    error_rate = errors / total if total else 0.0
    p99 = histogram_quantile(0.99, parsed["buckets"])
    return {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "total_requests": total,
        "error_requests": errors,
        "error_rate": error_rate,
        "p99_latency_seconds": p99,
        "mode": parsed["mode"],
        "uptime": parsed["uptime"],
        "chaos_active": parsed["chaos"],
        "raw": parsed,
    }


def evaluate_policy_compliance(manifest, snapshot):
    policy = manifest.get("policy", {})
    usage = shutil.disk_usage(ROOT)
    infra_input = {
        "disk_free": round(usage.free / (1024 ** 3), 2),
        "min_disk": float(policy.get("infra_min_disk_gb", 10)),
        "cpu_load": os.getloadavg()[0] if hasattr(os, "getloadavg") else 0.0,
        "max_cpu": float(policy.get("infra_max_cpu_load", 2.0)),
        "question": "status",
    }
    canary_input = {
        "error_rate": snapshot["error_rate"],
        "max_error_rate": float(policy.get("canary_max_error_rate", 0.01)),
        "p99_latency": snapshot["p99_latency_seconds"],
        "max_latency": float(policy.get("canary_max_p99_latency_seconds", 0.5)),
        "window_seconds": int(policy.get("canary_window_seconds", 30)),
        "question": "status",
    }
    return {
        "infra": {"input": infra_input, "decision": query_opa("infra", infra_input)},
        "canary": {"input": canary_input, "decision": query_opa("canary", canary_input)},
    }


# --- CLI Commands ---

def command_init(_args=None):
    """Parses manifest.yaml and generates docker-compose.yml and nginx.conf."""
    manifest = load_manifest()
    require_fields(manifest)

    service = manifest["services"]
    nginx = manifest["nginx"]
    network = manifest["network"]

    values = {
        "SERVICE_IMAGE": service["image"],
        "MODE": service.get("mode", "stable"),
        "VERSION": service.get("version", "v1"),
        "PORT": service["port"],
        "APP_PORT": service["port"],
        "NGINX_IMAGE": nginx["image"],
        "NGINX_PORT": nginx["port"],
        "PROXY_TIMEOUT": nginx.get("proxy_timeout", "10s"),
        "CONTACT": nginx.get("contact", "devops@example.com"),
        "NETWORK": network["name"],
        "DRIVER": network["driver_type"],
        "RESTART_POLICY": service.get("restart_policy", "unless-stopped"),
    }

    COMPOSE_FILE.write_text(render_template("docker-compose.yml.tpl", values), encoding="utf-8")
    NGINX_CONF.write_text(render_template("nginx.conf.tpl", values), encoding="utf-8")
    print("PASS: generated docker-compose.yml and nginx.conf")


def print_check(name, ok, detail=""):
    """Formatted output for validation steps."""
    status = "PASS" if ok else "FAIL"
    suffix = f" - {detail}" if detail else ""
    print(f"{status}: {name}{suffix}")


def port_is_free(port):
    """Checks if a host port is currently bound by another process."""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(1)
        return sock.connect_ex(("127.0.0.1", int(port))) != 0


def image_exists(image):
    """Checks if a Docker image is available on the local machine."""
    result = run(["docker", "image", "inspect", image], check=False, capture=True)
    return result.returncode == 0


def nginx_config_valid(image):
    """Mounts the generated nginx.conf to an ephemeral Nginx container to test syntax."""
    if not NGINX_CONF.exists():
        command_init()
    mount = f"{NGINX_CONF}:/etc/nginx/nginx.conf:ro"
    result = run(["docker", "run", "--rm", "-v", mount, image, "nginx", "-t"], check=False, capture=True)
    if result.returncode != 0:
        return False, (result.stderr or result.stdout).strip()
    return True, "nginx -t succeeded"


def command_validate(_args=None):
    """Runs a suite of pre-flight checks to ensure the deployment will succeed."""
    failed = False
    manifest = None

    if MANIFEST.exists():
        try:
            manifest = load_manifest()
            print_check("manifest.yaml exists and is valid YAML", True)
        except Exception as exc:
            failed = True
            print_check("manifest.yaml exists and is valid YAML", False, str(exc))
    else:
        failed = True
        print_check("manifest.yaml exists and is valid YAML", False, "file not found")

    if manifest is not None:
        try:
            require_fields(manifest)
            print_check("all required fields are present and non-empty", True)
        except Exception as exc:
            failed = True
            print_check("all required fields are present and non-empty", False, str(exc))
    else:
        failed = True
        print_check("all required fields are present and non-empty", False, "manifest could not be loaded")

    if manifest is not None:
        image = manifest["services"].get("image")
        ok = image_exists(image)
        failed = failed or not ok
        print_check("Docker image referenced in the manifest exists locally", ok, image)

        free = port_is_free(manifest["nginx"].get("port"))
        failed = failed or not free
        detail = f"port {manifest['nginx'].get('port')}"
        if not free:
            detail += " (is the stack already running? try: swiftdeploy teardown)"
        print_check("Nginx port is not already bound on the host", free, detail)

        ok, detail = nginx_config_valid(manifest["nginx"].get("image", "nginx:latest"))
        failed = failed or not ok
        print_check("generated nginx.conf is syntactically valid", ok, detail)

    if failed:
        sys.exit(1)
    print("VALIDATION PASSED")


def fetch_json(url, timeout=3):
    """Utility to make HTTP GET requests and parse JSON response."""
    with urllib.request.urlopen(url, timeout=timeout) as response:
        return json.loads(response.read().decode("utf-8"))


def wait_for_opa(timeout=20):
    manifest = load_manifest()
    opa_url = manifest.get("policy", {}).get("opa_url", "http://127.0.0.1:8181").rstrip("/")
    deadline = time.time() + timeout
    last_error = ""
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(f"{opa_url}/health?plugins", timeout=2) as response:
                if response.status < 500:
                    return True
        except Exception as exc:
            last_error = str(exc)
        time.sleep(1)
    print(f"OPA UNAVAILABLE: policy API did not become ready within {timeout}s ({last_error})")
    return False


def wait_for_health(port, expected_mode=None, timeout=60):
    """Blocks until the /healthz endpoint returns 'ok' and matches the expected mode."""
    deadline = time.time() + timeout
    url = f"http://127.0.0.1:{port}/healthz"
    last_error = ""
    while time.time() < deadline:
        try:
            data = fetch_json(url, timeout=3)
            if data.get("status") == "ok" and (expected_mode is None or data.get("mode") == expected_mode):
                return data
            last_error = f"unexpected response: {data}"
        except Exception as exc:
            last_error = str(exc)
        time.sleep(2)
    raise TimeoutError(f"health check failed after {timeout}s: {last_error}")


def command_deploy(_args=None):
    """Generates configs, starts Docker containers, and waits for health checks."""
    command_init()
    run(["docker", "compose", "up", "-d", "opa"])
    if not wait_for_opa():
        log_event("deploy", detail="blocked because OPA was unavailable", success=False)
        print("FAIL: Deployment aborted because policy enforcement is unavailable.")
        sys.exit(1)

    if not check_predeploy():
        log_event("deploy", detail="blocked by infra policy", success=False)
        print("FAIL: Deployment aborted due to policy violations.")
        sys.exit(1)

    run(["docker", "compose", "up", "-d", "--force-recreate"])
    manifest = load_manifest()
    data = wait_for_health(manifest["nginx"]["port"], manifest["services"].get("mode", "stable"), 60)
    log_event("deploy", detail=f"mode={data.get('mode')} version={manifest['services'].get('version', 'v1')}")
    print(f"DEPLOY SUCCESS: /healthz status={data.get('status')} mode={data.get('mode')} uptime={data.get('uptime')}")


def command_promote(args):
    """Switches deployment mode (e.g. stable to canary) with zero-downtime container recreation."""
    if args.mode not in {"stable", "canary"}:
        print("FAIL: promote mode must be stable or canary")
        sys.exit(1)

    manifest = load_manifest()
    require_fields(manifest)

    if not check_prepromote(manifest):
        log_event("promote", detail=f"to {args.mode} — blocked by canary policy", success=False)
        print("FAIL: Promotion aborted due to policy failure (Canary unhealthy).")
        sys.exit(1)

    old_mode = manifest["services"].get("mode", "stable")
    manifest.setdefault("services", {})["mode"] = args.mode
    save_manifest(manifest)
    command_init()
    run(["docker", "compose", "up", "-d", "--no-deps", "--force-recreate", "app"])
    data = wait_for_health(manifest["nginx"]["port"], args.mode, 60)
    log_event("promote", detail=f"{old_mode} -> {args.mode}")
    print(f"PROMOTE SUCCESS: active mode is {data.get('mode')}")


def command_teardown(args):
    """Stops and removes the entire Docker stack."""
    run(["docker", "compose", "down", "-v", "--remove-orphans"], check=False)
    if args.clean:
        for path in (COMPOSE_FILE, NGINX_CONF):
            if path.exists():
                path.unlink()
        log_event("teardown", detail="with --clean")
        print("STACK REMOVED: generated configs deleted")
    else:
        log_event("teardown")
        print("STACK REMOVED")


# --- Status Dashboard ---

def command_status(_args=None):
    """Displays a live dashboard of container health, mode, and resource usage."""
    print("=" * 60)
    print("  SWIFTDEPLOY STATUS DASHBOARD")
    print("=" * 60)

    # 1. Container status
    print("\n--- Containers ---")
    result = run(
        ["docker", "compose", "ps", "--format", "json"],
        check=False, capture=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        print("  No containers running (stack is down)")
        print("=" * 60)
        return

    containers = []
    for line in result.stdout.strip().splitlines():
        try:
            containers.append(json.loads(line))
        except json.JSONDecodeError:
            continue

    for c in containers:
        name = c.get("Name", c.get("Service", "?"))
        state = c.get("State", "unknown")
        health = c.get("Health", "n/a")
        status_line = c.get("Status", "")
        icon = "✓" if state == "running" else "✗"
        print(f"  {icon} {name:<20} state={state:<10} health={health:<12} {status_line}")

    # 2. App health via /healthz
    print("\n--- Application Health ---")
    try:
        manifest = load_manifest()
        port = manifest["nginx"]["port"]
        data = fetch_json(f"http://127.0.0.1:{port}/healthz", timeout=3)
        print(f"  Status : {data.get('status', '?')}")
        print(f"  Mode   : {data.get('mode', '?')}")
        print(f"  Uptime : {data.get('uptime', '?')}s")
    except Exception:
        print("  Could not reach /healthz (app may be starting)")

    # 3. Docker resource usage
    print("\n--- Resource Usage ---")
    stats = run(
        ["docker", "stats", "--no-stream", "--format",
         "table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}"],
        check=False, capture=True,
    )
    if stats.returncode == 0 and stats.stdout.strip():
        for line in stats.stdout.strip().splitlines():
            print(f"  {line}")
    else:
        print("  Unable to retrieve resource stats")

    # 4. Last 3 history events
    print("\n--- Recent Activity ---")
    if HISTORY_FILE.exists():
        lines = HISTORY_FILE.read_text(encoding="utf-8").strip().splitlines()
        recent = lines[-5:] if len(lines) >= 5 else lines
        for raw in recent:
            try:
                evt = json.loads(raw)
                ts = evt["timestamp"][:19].replace("T", " ")
                ok = "✓" if evt.get("success", True) else "✗"
                detail = evt.get("detail", "")
                print(f"  {ok} [{ts}] {evt['action']}  {detail}")
            except (json.JSONDecodeError, KeyError):
                continue
    else:
        print("  No history yet")

    print("=" * 60)


# --- Audit Report ---

def command_audit(_args=None):
    """Generates a summary report from the history.jsonl event log."""
    if not HISTORY_FILE.exists():
        print("No history.jsonl found. Deploy at least once to start logging.")
        return

    lines = HISTORY_FILE.read_text(encoding="utf-8").strip().splitlines()
    events = []
    for raw in lines:
        try:
            events.append(json.loads(raw))
        except json.JSONDecodeError:
            continue

    if not events:
        print("History file is empty.")
        return

    # Count actions
    counts = {}
    failures = 0
    for evt in events:
        action = evt.get("action", "unknown")
        counts[action] = counts.get(action, 0) + 1
        if not evt.get("success", True):
            failures += 1

    first_ts = events[0].get("timestamp", "?")[:19].replace("T", " ")
    last_ts = events[-1].get("timestamp", "?")[:19].replace("T", " ")

    print("=" * 60)
    print("  SWIFTDEPLOY AUDIT REPORT")
    print("=" * 60)
    print(f"\n  Period     : {first_ts}  →  {last_ts}")
    print(f"  Total Events: {len(events)}")
    print(f"  Failures   : {failures}")

    print("\n  --- Action Breakdown ---")
    for action, count in sorted(counts.items()):
        print(f"    {action:<15} {count}")

    print("\n  --- Full Timeline ---")
    for evt in events:
        ts = evt.get("timestamp", "?")[:19].replace("T", " ")
        ok = "✓" if evt.get("success", True) else "✗"
        detail = evt.get("detail", "")
        print(f"    {ok} [{ts}] {evt.get('action', '?'):<12} {detail}")

    print("\n" + "=" * 60)


# --- Stage 4B Status/Audit Overrides ---

def render_status_once(previous=None):
    manifest = load_manifest()
    snapshot = scrape_metrics_snapshot(manifest)
    compliance = evaluate_policy_compliance(manifest, snapshot)
    now = time.time()

    req_per_second = 0.0
    if previous:
        elapsed = max(now - previous["time"], 0.001)
        req_delta = max(snapshot["total_requests"] - previous["snapshot"]["total_requests"], 0)
        req_per_second = req_delta / elapsed

    append_history({
        "action": "metrics_scrape",
        "success": all(item["decision"].get("allow", False) for item in compliance.values()),
        "metrics": {
            "req_per_second": req_per_second,
            "p99_latency_seconds": snapshot["p99_latency_seconds"],
            "error_rate": snapshot["error_rate"],
            "mode": snapshot["mode"],
            "chaos_active": snapshot["chaos_active"],
        },
        "policy": compliance,
    })

    print("=" * 72)
    print("SWIFTDEPLOY STATUS")
    print("=" * 72)
    print(f"Time          : {snapshot['timestamp']}")
    print(f"Mode          : {'canary' if snapshot['mode'] == 1 else 'stable'}")
    print(f"Uptime        : {int(snapshot['uptime'] or 0)}s")
    print(f"Chaos         : {int(snapshot['chaos_active'] or 0)} (0=none, 1=slow, 2=error)")
    print(f"Throughput    : {req_per_second:.2f} req/s")
    print(f"Error rate    : {snapshot['error_rate']:.2%}")
    print(f"P99 latency   : {snapshot['p99_latency_seconds']:.3f}s")
    print("\nPolicy Compliance")
    for domain, item in compliance.items():
        decision = item["decision"]
        status = "PASS" if decision.get("allow", False) else "FAIL"
        reasons = decision.get("reasons") or ["policy allowed"]
        print(f"- {domain}: {status} - {'; '.join(str(reason) for reason in reasons)}")
    print("=" * 72)
    return {"time": now, "snapshot": snapshot}


def command_status(args):
    previous = None
    refreshes = args.count
    while refreshes is None or refreshes > 0:
        try:
            os.system("cls" if os.name == "nt" else "clear")
            previous = render_status_once(previous)
        except Exception as exc:
            append_history({"action": "metrics_scrape", "success": False, "detail": f"status failed: {exc}"})
            print(f"STATUS UNAVAILABLE: {exc}")
        if refreshes is not None:
            refreshes -= 1
            if refreshes <= 0:
                break
        time.sleep(args.interval)


def command_audit(_args=None):
    if not HISTORY_FILE.exists():
        print("No history.jsonl found. Deploy or run status first to start logging.")
        return

    events = []
    for raw in HISTORY_FILE.read_text(encoding="utf-8").strip().splitlines():
        try:
            events.append(json.loads(raw))
        except json.JSONDecodeError:
            continue
    if not events:
        print("History file is empty.")
        return

    counts = {}
    violations = []
    timeline = []
    for evt in events:
        action = evt.get("action", "unknown")
        counts[action] = counts.get(action, 0) + 1
        if not evt.get("success", True):
            violations.append(evt)
        if action in {"deploy", "promote", "chaos", "policy_check", "metrics_scrape"}:
            timeline.append(evt)

    first_ts = events[0].get("timestamp", "?")[:19].replace("T", " ")
    last_ts = events[-1].get("timestamp", "?")[:19].replace("T", " ")
    report = [
        "# SwiftDeploy Audit Report",
        "",
        f"**Period:** {first_ts} -> {last_ts}",
        f"**Total events:** {len(events)}",
        f"**Policy violations / failures:** {len(violations)}",
        "",
        "## Action Breakdown",
        "",
        "| Action | Count |",
        "| --- | ---: |",
    ]
    for action, count in sorted(counts.items()):
        report.append(f"| {action} | {count} |")

    report.extend(["", "## Timeline", "", "| Time UTC | Action | Success | Summary |", "| --- | --- | --- | --- |"])
    for evt in timeline:
        ts = evt.get("timestamp", "?")[:19].replace("T", " ")
        ok = "yes" if evt.get("success", True) else "no"
        detail = evt.get("detail", "")
        if isinstance(detail, list):
            detail = "; ".join(str(item) for item in detail)
        if evt.get("action") == "metrics_scrape":
            metrics = evt.get("metrics", {})
            detail = f"mode={metrics.get('mode')} p99={metrics.get('p99_latency_seconds')} error_rate={metrics.get('error_rate')}"
        report.append(f"| {ts} | {evt.get('action', '?')} | {ok} | {str(detail).replace('|', '/')} |")

    report.extend(["", "## Violations", ""])
    if violations:
        report.extend(["| Time UTC | Action | Reason |", "| --- | --- | --- |"])
        for evt in violations:
            ts = evt.get("timestamp", "?")[:19].replace("T", " ")
            detail = evt.get("detail", "")
            if isinstance(detail, list):
                detail = "; ".join(str(item) for item in detail)
            report.append(f"| {ts} | {evt.get('action', '?')} | {str(detail).replace('|', '/')} |")
    else:
        report.append("No policy violations were recorded.")
    report.append("")

    AUDIT_REPORT.write_text("\n".join(report), encoding="utf-8")
    print(f"PASS: generated {AUDIT_REPORT.name}")


# --- CLI Parser ---

def build_parser():
    """Defines the CLI argument structure."""
    parser = argparse.ArgumentParser(prog="swiftdeploy")
    subcommands = parser.add_subparsers(dest="command", required=True)

    subcommands.add_parser("init").set_defaults(func=command_init)
    subcommands.add_parser("validate").set_defaults(func=command_validate)
    subcommands.add_parser("deploy").set_defaults(func=command_deploy)
    status = subcommands.add_parser("status")
    status.add_argument("--interval", type=float, default=2.0)
    status.add_argument("--count", type=int, default=None)
    status.set_defaults(func=command_status)
    subcommands.add_parser("audit").set_defaults(func=command_audit)

    promote = subcommands.add_parser("promote")
    promote.add_argument("mode", choices=["stable", "canary"])
    promote.set_defaults(func=command_promote)

    teardown = subcommands.add_parser("teardown")
    teardown.add_argument("--clean", action="store_true")
    teardown.set_defaults(func=command_teardown)
    return parser


def main():
    """Main entrypoint for the CLI."""
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except subprocess.CalledProcessError as exc:
        print(f"FAIL: command failed: {' '.join(exc.cmd)}")
        if exc.stderr:
            print(exc.stderr.strip())
        sys.exit(exc.returncode)
    except Exception as exc:
        print(f"FAIL: {exc}")
        sys.exit(1)


if __name__ == "__main__":
    main()
